# ShadowBroker Backend — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Required Keys ──────────────────────────────────────────────
# Without these, the corresponding data layers will be empty.

OPENSKY_CLIENT_ID=        # https://opensky-network.org/ — free account, OAuth2 client ID
OPENSKY_CLIENT_SECRET=    # OAuth2 client secret from your OpenSky dashboard
AIS_API_KEY=              # https://aisstream.io/ — free tier WebSocket key

# ── Optional ───────────────────────────────────────────────────

# Override allowed CORS origins (comma-separated). Defaults to localhost + LAN auto-detect.
# CORS_ORIGINS=http://192.168.1.50:3000,https://my-domain.com

# Admin key — protects sensitive endpoints (API key management, system update).
# If unset, these endpoints remain open (fine for local dev).
# Set this in production and enter the same key in Settings → Admin Key.
# ADMIN_KEY=your-secret-admin-key-here

# LTA Singapore traffic cameras — leave blank to skip this data source.
# LTA_ACCOUNT_KEY=


# — NASA APIs —————————————————————————————
# NASA FIRMS fire detection API keys (get from https://firms.modaps.eosdis.nasa.gov/api/area/)
NASA_FIRMS_KEY=
NASA_FIRMS_MAP_KEY=

# NASA general API key (APOD, Earth imagery, etc.) — get from https://api.nasa.gov/
# DEMO_KEY works but is rate-limited (30 req/hour)
NASA_API_KEY=DEMO_KEY

# NASA EOSDIS / Earthdata Login token (EDL JWT) — for CMR granule search
# Get from: https://urs.earthdata.nasa.gov/ → Generate Token
NASA_EOSDIS_TOKEN=

# — OpenRouter AI LLM ——————————————————————
# Get from https://openrouter.ai/ — used for OSINT AI analysis
OPENROUTER_API_KEY=

# — AISStream WebSocket API keys ———————————
# Primary and secondary keys from https://aisstream.io/
AIS_API_KEY=
AIS_API_KEY_2=

# — Google Flood Hub ————————————————————
# Public API - no key needed; set region focus
FLOOD_HUB_REGION=

# — ADS-B Exchange —————————————————————
# RapidAPI key for ADS-B Exchange v2 data
ADSB_EXCHANGE_API_KEY=
ADSB_EXCHANGE_BASE_URL=https://adsbexchange-com1.p.rapidapi.com/v2