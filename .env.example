# ShadowBroker — Environment Variables
# cp .env.example .env  — then fill in your keys
# SECURITY: Never commit the actual .env file (it is gitignored)

# =============================================================================
# KEYLESS MODE — these run with zero keys:
#   adsb.lol aircraft, CelesTrak satellites, USGS quakes, GDELT, DeepState,
#   TfL/Austin TX/NYC DOT cameras, NOAA SWPC, IODA, KiwiSDR, NASA GIBS
# =============================================================================

# --- AIS Stream (aisstream.io) -----------------------------------------------
# Real-time maritime vessel tracking. Without this key vessels layer is empty.
# FREE key: https://aisstream.io/
AIS_API_KEY=

# --- NASA FIRMS (Fire Information for Resource Management System) ------------
# Enhanced fire/thermal hotspot data with higher resolution & more sources.
# FREE key: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_KEY=
NASA_FIRMS_MAP_KEY=

# --- NASA Earthdata (EOSDIS) -------------------------------------------------
# Access to MODIS, VIIRS, Sentinel imagery via NASA EarthData APIs.
# FREE: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_TOKEN=

# --- Google Flood Hub API ----------------------------------------------------
# Real-time riverine flood forecasts for 240,000+ gauge locations worldwide.
# Pilot program: https://developers.google.com/flood-forecasting
GOOGLE_FLOOD_API_KEY=

# --- OpenRouter LLM API ------------------------------------------------------
# AI-powered OSINT analysis, event summarization, threat assessment.
# Get key: https://openrouter.ai/
OPENROUTER_API_KEY=

# --- OpenSky Network OAuth2 --------------------------------------------------
# Higher rate limits for flight coverage in Africa/Asia/South America.
# FREE: https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- LTA Singapore cameras ---------------------------------------------------
# Adds ~90 Singapore road cameras to CCTV mesh.
# FREE: https://datamall.lta.gov.sg/
LTA_ACCOUNT_KEY=

# --- Backend networking ------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000
